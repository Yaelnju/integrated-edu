# 复制为 application.properties 后按本机 SQL Server 修改
# 学院 A 仅使用真实 SQL Server，不使用 SQLite

# ---------- 方式一：SQL 账号登录（推荐作业演示）----------
# 安装时启用“混合模式”，使用 sa 或自建登录名
db.url=jdbc:sqlserver://localhost:1433;databaseName=CollegeA_DB;encrypt=true;trustServerCertificate=true
db.user=sa
db.password=请改成你的SA密码

# ---------- 方式二：Windows 身份验证 ----------
# 需本机安装 Microsoft JDBC 驱动支持的 integratedSecurity（Windows 上可用）
# db.url=jdbc:sqlserver://localhost\\SQLEXPRESS;databaseName=CollegeA_DB;integratedSecurity=true;encrypt=true;trustServerCertificate=true
# db.user=
# db.password=

# ---------- 命名实例示例（SQL Server Express 默认实例名 SQLEXPRESS）----------
# db.url=jdbc:sqlserver://localhost\\SQLEXPRESS;databaseName=CollegeA_DB;encrypt=true;trustServerCertificate=true

college.a.gui.port=9002
college.a.xml.port=9102
integration.server.port=9200

college.b.xml.host=127.0.0.1
college.b.xml.port=9101
college.c.xml.host=127.0.0.1
college.c.xml.port=9100
college.b.gui.port=9001
college.c.gui.port=9000
